+  </div>
+  {{- end }}
+</header>
+{{- end }}
+
+{{ .Content }}
+
+{{/* Web3 Landing Page: /web3/ */}}
+{{- if eq .RelPermalink "/web3/" }}
+
+{{/* Skills as a 3-column grid row */}}
+{{- $skills := where (where site.RegularPages "Section" "web3") "Params.skill_type" "!=" nil }}
+{{- if gt (len $skills) 0 }}
+<h2 class="web3-section-heading">Security Capabilities</h2>
+<div class="web3-skills-row">
