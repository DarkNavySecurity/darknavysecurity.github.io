+#!/usr/bin/env python3
+"""
+Sync exploit analysis reports from ~/web3-exploit-analysis into Hugo content.
+
+Parses the README.md table for metadata (date, chain, title, report path),
+then extracts loss amount and vulnerability category from each report.
+Generates Hugo-compatible markdown files with front matter.
+"""
+
+import os
+import re
+import sys
+import shutil
+from pathlib import Path
+
+EXPLOIT_DIR = Path(os.path.expanduser("~/web3-exploit-analysis"))
+HUGO_DIR = Path(os.path.expanduser("~/darknavysecurity.github.io"))
+CONTENT_DIR = HUGO_DIR / "content" / "en" / "web3" / "exploits"
+README_PATH = EXPLOIT_DIR / "README.md"
+
+# Map chain names from README table to Hugo-friendly slugs with display names
+CHAIN_MAP = {
+    "Ethereum": {"slug": "ethereum", "color": "#7aa2f7"},
+    "BNB": {"slug": "bsc", "color": "#f7768e"},
+    "BSC": {"slug": "bsc", "color": "#f7768e"},
+    "Arbitrum": {"slug": "arbitrum", "color": "#7dcfff"},
+    "Polygon": {"slug": "polygon", "color": "#9ece6a"},
+    "Polygon zkEVM": {"slug": "polygon-zkevm", "color": "#9ece6a"},
+    "Optimism": {"slug": "optimism", "color": "#e0af68"},
+    "Avalanche": {"slug": "avalanche", "color": "#bb9af7"},
+    "Base": {"slug": "base", "color": "#7aa2f7"},
+    "Linea": {"slug": "linea", "color": "#bb9af7"},
+}
+
+# Manual overrides for loss/vuln_type that auto-extraction can't reliably detect.
+# Key = slugified incident name, Value = fields to override.
+MANUAL_OVERRIDES = {
+    "denaria-finance-virtual-amm-manipulation": {"vuln_type": "AMM State Manipulation"},
+    "dbxen-erc2771-confusion": {"loss": "22.53 BNB + 9,677 DXN"},
+    "eywa-portalv2-axelar": {"loss": "999,787,453 EYWA"},
+    "gondi-purchasebundler-drain": {"loss": "39 NFTs"},
+    "gyro-finance-ccip-escrow": {"loss": "6,099,337 GYD (~300.2 ETH)"},
+    "hpay-staking-forceexit-drain": {"loss": "58.7M HPAY (~26.01 BNB)"},
+    "inugami-staking-reward-debt-drain": {"loss": "13.9 WBNB (~8.75K USD)"},
+    "lml-apower-reward-claim-price-manipulation": {"loss": "~310K USDT"},
+    "makina-oracle-manipulation": {"loss": "See report", "vuln_type": "Oracle Manipulation", "tx_hash": "0xd063b3848a6b8c67f46990ab166665d454147855819acb60c083c0aea0180b2d"},
+    "movie-token-burn-manipulation": {"loss": "381.75 WBNB (~242K USD)"},
+    "neutrl-nusd-internal-balance": {"loss": "45,907 USDC", "vuln_type": "Internal Balance Manipulation"},
+    "planet-finance-lending": {"loss": "Attack failed (reverted)", "vuln_type": "Oracle Manipulation"},
+    "sto-deflationary-burn-drain": {"loss": "26.57 BNB (~16.1K USD)", "tx_hash": "0x8ba17bea937f062743ef85b1f1f22504d79b2499dece96ccb6171aae5a54020c"},
+    "usde-safe-module-flashloan": {"loss": "63,967 USDe", "vuln_type": "Access Control Bypass", "tx_hash": "0xa1301596c77938cb31cbd282da79f6499f23cd8ffff5e609a77216ea1cf040a4"},
+    "vtswaphook-pricing-error": {"loss": "~2M ATH + ~4.5M vATH"},
+    "whalebit-ces-igt-staking-oracle-manipulation": {"loss": "10,506 CES"},
+    "wukong-staking-reentrancy": {"loss": "57.68 BNB (~33.5K USD)"},
+    "xpl": {"loss": "718,844 USDT (~718K USD)"},
+    "fee-token-skim-exploit": {"vuln_type": "Skim Attack"},
+    "infinitysix-twap-stale-price": {"vuln_type": "Stale TWAP Price"},
+    "uniswap-v4-hook-swap-drain": {"vuln_type": "Calldata Manipulation", "tx_hash": "0xa17dc37e1b65c65d20042212fb834974f7faaa961442e3fc05393778705f8474"},
+    "veil-cash-groth16-forgery": {"vuln_type": "ZK Proof Forgery"},
+    "reusd-singleadapterrouter-withdraw": {"vuln_type": "Unauthorized Withdraw"},
+    "tmx-tribe": {"loss": "~1.4M USD", "vuln_type": "Accounting Error", "tx_hash": "0x00eed3660badc8f02855d6cf5b8e2fbb521a1208752745e1419077c42e948a0f"},
+    "cow-protocol-solver-exploit": {"loss": "50.4M aEthUSDT", "vuln_type": "Phishing"},
+    "est-bnbdeposit-claim-manipulation": {"vuln_type": "Claim Manipulation"},
+    "usdc-permit-phishing-drain": {"loss": "~1.77M USDC", "vuln_type": "Phishing"},
+    "aave-fork-undercollateralized-borrow": {"vuln_type": "Oracle Misconfiguration", "tx_hash": "0x2f1c33eaaaace728f6101ff527793387341021ef465a4a33f53a0037f5bd1626"},
+    "hyperbridge-ismp-forged-proof-dot-mint": {"loss": "108.2 ETH (~237K USD)", "vuln_type": "Forged Proof Access Control"},
+    "subquery-settings-access-control-staking-drain": {"loss": "218.3M SQT (~131K USD)"},
+    # tx_hash overrides for reports where auto-extraction fails
+    "bubu2-fee-token-staking-drain": {"tx_hash": "0x5d54fa839821e370b020d13a9b11b6f4f8cadc4eaed0a404ea17ad1bd725dbde"},
+    "gamma-lending-exploit": {"tx_hash": "0xe0835bb761805689bf3ee510c5b0950ead03977f3d99ddc1a59c6d23151c0f1f"},
+    "usdc-permit-phishing-drain": {"tx_hash": "0xfd7417af8433e3d9bcbed3f965307c800a24eb4e98f42cebfab6ca6064f5a642"},
+}
+
+
+def parse_readme_table(readme_path: Path) -> list[dict]:
+    """Parse the README.md report table into a list of report metadata."""
+    content = readme_path.read_text()
+    rows = []
+    # Match table rows: | date | chain | incident | report link |
+    pattern = re.compile(
+        r'\|\s*(\d{4}-\d{2}-\d{2})\s*\|\s*([^|]+?)\s*\|\s*([^|]+?)\s*\|\s*\[report\]\(([^)]+)\)\s*\|'
+    )
+    for match in pattern.finditer(content):
+        date_str = match.group(1).strip()
+        chain = match.group(2).strip()
+        incident = match.group(3).strip()
+        report_rel = match.group(4).strip()
+        rows.append({
+            "date": date_str,
+            "chain": chain,
+            "incident": incident,
+            "report_path": EXPLOIT_DIR / report_rel,
+        })
+    return rows
+
+
+def extract_loss(report_content: str) -> str:
+    """Extract loss/impact amount with currency unit from report content."""
+    summary = report_content[:2000]
+    # Patterns that capture amount + unit together
+    patterns = [
+        # "drained approximately **165,618 USDC**"
+        r'\*\*([\d,]+\.?\d*)\s*(USDC|USDT|USD|ETH|BTC|WETH|WBTC|CAKE|WBNB|dUSD|BRO|SolvBTC|aEthUSDT)\*\*',
+        # "$50.4M" or "$50.4 million"
+        r'\$([\d,]+\.?\d*)\s*(million|M|billion|B)',
+        # "~1.58 M USDC" or "~165,618 USDC"
+        r'~([\d,]+\.?\d*\s*(?:M|million|B|billion)?)\s*(USDC|USDT|USD|ETH|BTC|WETH|WBTC|CAKE|WBNB|dUSD)',
+        # "165,618 USDC" (amount + unit after drained/lost/stolen)
+        r'(?:drained|lost|extracted|stolen|profit|net gain|net cost).*?([\d,]+\.?\d*\s*(?:M|million|B|billion)?)\s*(USDC|USDT|USD|ETH|BTC|WETH|WBTC|CAKE|WBNB|dUSD|BRO|SolvBTC|aEthUSDT)',
+        # "1,211.05 ETH"
+        r'([\d,]+\.?\d*)\s*(ETH|WETH|USDC|USDT|BTC|WBTC)',
+    ]
+    for pat in patterns:
+        matches = re.findall(pat, summary, re.IGNORECASE)
+        if matches:
+            amount, unit = matches[0]
+            amount = amount.strip()
+            unit = unit.strip()
+            # Normalize unit names
+            unit_map = {"M": "M", "million": "M", "B": "B", "billion": "B"}
+            for k, v in unit_map.items():
+                if amount.lower().endswith(k):
+                    amount = amount[: -len(k)].strip() + v
+                    break
+            return f"{amount} {unit}"
+    return ""
+
+
+def extract_vuln_type(report_content: str) -> str:
+    """Extract vulnerability category from report content."""
+    summary = report_content[:3000]
+    # Look for Attack Type in table
+    patterns = [
+        r'\|\s*Attack Type\s*\|\s*([^|]+)\s*\|',
+        r'\|\s*Root Cause\s*\|\s*([^|]+)\s*\|',
+    ]
+    for pat in patterns:
+        match = re.search(pat, summary)
+        if match:
+            return match.group(1).strip()
+
+    # Fallback: search for common vulnerability keywords in order of specificity
+    keywords = [
+        "Reentrancy", "Flash Loan", "Oracle Manipulation", "Price Manipulation",
+        "Access Control", "Storage Collision", "Storage Aliasing",
+        "Integer Overflow", "Signature Forgery", "Signature Replay",
+        "Callback", "Front-running", "Sandwich", "Phishing",
+        "Logic Error", "Accounting Error", "Precision Loss",
+        "Exchange Rate Manipulation", "Index Manipulation",
+        "Unauthorized Borrow", "ERC-2771 Confusion",
+        "Double Mint", "Burn Manipulation", "Skim Attack",
+        "Calldata Manipulation", "Under-constraint",
+    ]
+    for kw in keywords:
+        if kw.lower() in summary.lower():
+            return kw
+
+    return "Unknown"
+
+
+def extract_tx_hash(report_content: str) -> str:
+    """Extract the primary transaction hash from the report."""
+    patterns = [
+        # Markdown table: | Transaction Hash | `0x...` |
+        r'\|\s*Transaction\s*Hash\s*\|\s*`?(0x[a-fA-F0-9]{64})`?\s*\|',
+        # Markdown table: | Transaction | `0x...` |
+        r'\|\s*Transaction\s*\|\s*`?(0x[a-fA-F0-9]{64})`?\s*\|',
+        # Bold: **Transaction:** `0x...`
+        r'\*\*Transaction:\*\*\s*`?(0x[a-fA-F0-9]{64})`?',
+        # Link: Transaction: https://...tx/0x...
+        r'Transaction:\s*https?://[^\s]*tx/(0x[a-fA-F0-9]{64})',
+        # Backtick: tx `0x...`
+        r'tx\s*`(0x[a-fA-F0-9]{64})`',
+        # transaction `0x...` (in description/summary)
+        r'transaction\s*`(0x[a-fA-F0-9]{64})`',
+        # Plain: Transaction: `0x...`
+        r'Transaction:\s*`?(0x[a-fA-F0-9]{64})`?',
+        # On-chain transaction
+        r'\*\*On-chain transaction\*\*:\s*`?(0x[a-fA-F0-9]{64})`?',
+        # Any URL with tx/0x...
+        r'tx/(0x[a-fA-F0-9]{64})',
+    ]
+    for pat in patterns:
+        match = re.search(pat, report_content, re.IGNORECASE)
+        if match:
+            return match.group(1)
+    return ""
+
+
+def slugify(text: str) -> str:
+    """Convert text to URL-friendly slug."""
+    text = text.lower()
+    text = re.sub(r'[^a-z0-9]+', '-', text)
+    return text.strip('-')
+
+
+def extract_summary(report_content: str) -> str:
+    """Extract the first substantial paragraph from the report as summary."""
+    # Skip the title line, find first real paragraph
+    lines = report_content.split('\n')
+    paragraph = []
+    started = False
+    for line in lines:
+        stripped = line.strip()
+        if not started:
+            # Skip title and blank lines
+            if stripped.startswith('#') or not stripped:
+                continue
+            started = True
+        if started:
+            if not stripped:
+                if paragraph:
+                    break
+                continue
+            # Skip lines that are table rows or headers
+            if stripped.startswith('|') or stripped.startswith('##'):
+                if paragraph:
+                    break
+                continue
+            paragraph.append(stripped)
+    result = ' '.join(paragraph)
+    # Truncate to ~300 chars for summary
+    if len(result) > 300:
+        result = result[:300] + '...'
+    return result
+
+
+def generate_hugo_report(report_meta: dict) -> bool:
+    """Generate a Hugo content file for a single report."""
+    report_path = report_meta["report_path"]
+    if not report_path.exists():
+        print(f"  SKIP (not found): {report_path}")
+        return False
+
+    content = report_path.read_text()
+    if not content.strip():
+        print(f"  SKIP (empty): {report_path}")
+        return False
+
+    loss = extract_loss(content)
+    vuln_type = extract_vuln_type(content)
+    summary = extract_summary(content)
+    tx_hash = extract_tx_hash(content)
+    chain_info = CHAIN_MAP.get(report_meta["chain"], {"slug": "ethereum", "color": "#7aa2f7"})
+
+    # Create slug from incident name
+    slug = slugify(report_meta["incident"])
+    if not slug:
+        slug = report_path.parent.name
+
+    # Apply manual overrides — always win over auto-extracted values
+    if slug in MANUAL_OVERRIDES:
+        for key, value in MANUAL_OVERRIDES[slug].items():
+            if key == "loss":
+                loss = value
+            elif key == "vuln_type":
+                vuln_type = value
+            elif key == "tx_hash":
+                tx_hash = value
+
+    # Create output directory
+    out_dir = CONTENT_DIR / slug
+    out_dir.mkdir(parents=True, exist_ok=True)
+    out_file = out_dir / "index.md"
+
+    # Escape quotes for front matter
+    safe_summary = summary.replace('"', '\\"')
+
+    # Build front matter
+    front_matter = f"""---
+title: "{report_meta['incident'].replace('"', '\\"')}"
+description: "{safe_summary}"
+date: {report_meta['date']}
+draft: false
+chain: "{chain_info['slug']}"
+chain_display: "{report_meta['chain']}"
+loss: "{loss}"
+vuln_type: "{vuln_type}"
+tx_hash: "{tx_hash}"
+summary: "{safe_summary}"
+---
+
+"""
+    # Write the file: front matter + original report content
+    out_file.write_text(front_matter + content)
+    print(f"  OK: {slug}")
+    return True
+
+
+def main():
+    print("Syncing exploit analysis reports...")
+
+    if not README_PATH.exists():
+        print(f"ERROR: {README_PATH} not found")
+        sys.exit(1)
+
+    # Parse metadata from README table
+    reports = parse_readme_table(README_PATH)
+    print(f"Found {len(reports)} reports in README table")
+
+    # Clean existing exploit content
+    if CONTENT_DIR.exists():
+        for item in CONTENT_DIR.iterdir():
+            if item.is_dir():
+                shutil.rmtree(item)
+    CONTENT_DIR.mkdir(parents=True, exist_ok=True)
+
+    # Generate Hugo content for each report
+    success = 0
+    for report_meta in reports:
+        if generate_hugo_report(report_meta):
+            success += 1
+
+    # Regenerate exploits index
+    index_file = CONTENT_DIR / "_index.md"
+    index_file.write_text("""---
+title: "Exploit Analysis Reports"
+description: "On-chain exploit analysis reports with root cause analysis, code snippets, and attack flow walkthroughs"
+draft: false
+---
+""")
+
+    print(f"\nDone: {success}/{len(reports)} reports synced to {CONTENT_DIR}")
+
+
+if __name__ == "__main__":
+    main()
