+  {{- end }}
+</div>
+{{- end }}
+
+{{ end }}
+
+{{/* Report list — one per row, like blog posts */}}
+{{- $exploits := where (where site.RegularPages "Section" "web3") "Params.chain" "!=" nil }}
+{{- $paginator := .Paginate $exploits }}
+
+{{- if gt (len $exploits) 0 }}
+
+<h2 class="web3-section-heading">Exploit Analysis Reports</h2>
+
+<div class="web3-search-box">
+  <input type="text" id="web3-search" placeholder="Search reports..." class="web3-search-input">
+</div>
+
+<div id="web3-report-list">
+{{- range $paginator.Pages }}
+<article class="web3-report-entry" data-search="{{ lower .Title }} {{ lower .Params.chain_display }} {{ lower .Params.vuln_type }}">
+  <header class="entry-header">
+    <h2 class="entry-hint-parent">{{ .Title }}</h2>
